{
    "hooks": {
        "SubagentStop": [
            {
                "matcher": "implementation-executor",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/verify_impl_task.py",
                        "timeout": 180
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/post_compiled_script.py",
                        "timeout": 60,
                        "statusMessage": "Post compiled script hook fired"
                    }
                ]
            }
        ]
    }
}
