{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": ".*",
                "async": true,
                "hooks": [
                    {
                        "type": "command",
                        "command": "CLAUDE_PLUGIN_ROOT=${CLAUDE_PLUGIN_ROOT} uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/metrics_hook.py",
                        "timeout": 10000
                    }
                ]
            }
        ],
        "PostToolUseFailure": [
            {
                "matcher": ".*",
                "async": true,
                "hooks": [
                    {
                        "type": "command",
                        "command": "CLAUDE_PLUGIN_ROOT=${CLAUDE_PLUGIN_ROOT} uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/metrics_hook.py",
                        "timeout": 10000
                    }
                ]
            }
        ]
    }
}
